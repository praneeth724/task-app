NODE_ENV=development
PORT=4000

# MySQL connection string (MAMP defaults: user root / password root, port 3306)
DATABASE_URL="mysql://root:root@localhost:3306/task_tracker"

# Used for integration tests (separate database recommended)
TEST_DATABASE_URL="mysql://root:root@localhost:3306/task_tracker_test"

JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="1d"

# Comma-separated list of allowed frontend origins for CORS + Socket.IO
CORS_ORIGIN="http://localhost:3000"
