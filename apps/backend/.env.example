NODE_ENV=development
PORT=4000

# Postgres connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/task_tracker?schema=public"

# Used for integration tests (separate DB/schema recommended)
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/task_tracker_test?schema=public"

JWT_SECRET="replace-with-a-long-random-string"
JWT_EXPIRES_IN="1d"

# Comma-separated list of allowed frontend origins for CORS + Socket.IO
CORS_ORIGIN="http://localhost:3000"
