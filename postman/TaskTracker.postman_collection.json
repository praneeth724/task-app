{
  "info": {
    "name": "Task Tracker API",
    "description": "Full-stack Task Tracker: auth (register/login), RBAC'd task CRUD with pagination/filtering, and admin user listing. Run 'Auth' requests first to populate {{userToken}}/{{adminToken}}/{{userId}}, then the Tasks folder auto-fills {{taskId}}.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (regular user)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "if (res.token) { pm.environment.set('userToken', res.token); }",
                  "if (res.user) { pm.environment.set('userId', res.user.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo User\",\n  \"email\": \"user@tasktracker.dev\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        },
        {
          "name": "Login (regular user)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "if (res.token) { pm.environment.set('userToken', res.token); }",
                  "if (res.user) { pm.environment.set('userId', res.user.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@tasktracker.dev\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        },
        {
          "name": "Login (admin - seeded)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('status is 200', () => pm.response.to.have.status(200));",
                  "if (res.token) { pm.environment.set('adminToken', res.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@tasktracker.dev\",\n  \"password\": \"Password123!\"\n}"
            },
            "description": "Requires the backend to have been seeded via `npm run prisma:seed --workspace apps/backend`."
          }
        }
      ]
    },
    {
      "name": "Tasks (as User)",
      "item": [
        {
          "name": "Create task",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "pm.test('status is 201', () => pm.response.to.have.status(201));",
                  "if (res.id) { pm.environment.set('taskId', res.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": { "raw": "{{baseUrl}}/api/tasks", "host": ["{{baseUrl}}"], "path": ["api", "tasks"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Write the README\",\n  \"description\": \"Cover setup, design decisions and assumptions\",\n  \"status\": \"TODO\",\n  \"dueDate\": \"2026-08-01\"\n}"
            }
          }
        },
        {
          "name": "List my tasks (paginated)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/tasks?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Filter my tasks by status",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/tasks?status=TODO",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"],
              "query": [{ "key": "status", "value": "TODO" }]
            }
          }
        },
        {
          "name": "Get task by id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}"]
            }
          }
        },
        {
          "name": "Update task",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{userToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}"]
            },
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"IN_PROGRESS\"\n}" }
          }
        },
        {
          "name": "Delete task",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/tasks/{{taskId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "{{taskId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Tasks (as Admin / RBAC)",
      "item": [
        {
          "name": "List all tasks (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/tasks", "host": ["{{baseUrl}}"], "path": ["api", "tasks"] }
          }
        },
        {
          "name": "Filter all tasks by owner (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/tasks?owner={{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"],
              "query": [{ "key": "owner", "value": "{{userId}}" }]
            }
          }
        },
        {
          "name": "RBAC: user reading another user's task -> 403",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('status is 403 (or 404 if task was already deleted)', () => {",
                  "  pm.expect([403, 404]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/tasks/00000000-0000-0000-0000-000000000000",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks", "00000000-0000-0000-0000-000000000000"]
            },
            "description": "Replace the id with a real task id owned by a different user to see the 403 RBAC response."
          }
        },
        {
          "name": "RBAC: user listing all tasks via owner filter is ignored -> only own tasks",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/tasks?owner={{userId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"],
              "query": [{ "key": "owner", "value": "{{userId}}" }]
            },
            "description": "USER role always gets forced to their own ownerId server-side regardless of the owner query param."
          }
        },
        {
          "name": "RBAC: request without token -> 401",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('status is 401', () => pm.response.to.have.status(401));"] }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/tasks", "host": ["{{baseUrl}}"], "path": ["api", "tasks"] }
          }
        }
      ]
    },
    {
      "name": "Users (Admin only)",
      "item": [
        {
          "name": "List users (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/users", "host": ["{{baseUrl}}"], "path": ["api", "users"] }
          }
        },
        {
          "name": "List users as non-admin -> 403",
          "event": [
            {
              "listen": "test",
              "script": { "exec": ["pm.test('status is 403', () => pm.response.to.have.status(403));"] }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
            "url": { "raw": "{{baseUrl}}/api/users", "host": ["{{baseUrl}}"], "path": ["api", "users"] }
          }
        }
      ]
    }
  ]
}
